{
    "expo": {
        "name": "Rental Viewer",
        "slug": "rental-viewer",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "rental-viewer",
        "userInterfaceStyle": "automatic",
        "splash": {
            "resizeMode": "contain",
            "backgroundColor": "#1E3A5F"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.rental.viewer"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#1E3A5F"
            },
            "package": "com.rental.viewer"
        },
        "web": {
            "bundler": "metro",
            "output": "static",
            "favicon": "./assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            "expo-font",
            [
                "expo-location",
                {
                    "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
                }
            ]
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}