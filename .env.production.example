# Copy to .env.production at repository root on VPS.
# Then deploy with: docker compose --env-file .env.production up -d --build

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=rental

# Leave blank to auto-resolve to current host (:3000) in browser clients.
NEXT_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_BASE_URL=
VITE_API_BASE_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Backend captcha verification secret (Cloudflare Turnstile)
TURNSTILE_SECRET_KEY=
