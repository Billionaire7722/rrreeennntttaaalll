# Copy to backend/.env.production on VPS and fill real secrets.
# Never commit backend/.env.production.

DATABASE_URL="postgresql://postgres:CHANGE_ME@postgres:5432/rental?schema=public"
REDIS_HOST=redis
REDIS_PORT=6379

JWT_SECRET="CHANGE_ME_STRONG_SECRET"
PORT=3000
CORS_ORIGIN="https://your-viewer-domain.com,https://your-admin-domain.com"
ENABLE_SWAGGER=false

SUPER_ADMIN_EMAIL="ceo@rentalapp.com"
SUPER_ADMIN_USERNAME="superadmin_ceo"
SUPER_ADMIN_PASSWORD="CHANGE_ME_SUPER_ADMIN_PASSWORD"

# Prefer a single Cloudinary URL in production:
# CLOUDINARY_URL="cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>"
CLOUDINARY_URL=""

# Fallback style (only if CLOUDINARY_URL is empty)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
