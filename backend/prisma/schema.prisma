generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  SUPER_ADMIN
  USER
}

model House {
  id                  String   @id @default(uuid())
  original_id         String   @unique
  name                String
  property_type       String?
  address             String
  ward                String?
  ward_code           String?
  district            String?
  city                String
  city_code           String?
  latitude            Float?
  longitude           Float?
  price               Int?
  payment_method      String?
  bedrooms            Int?
  floors              Int?
  toilets             Int?
  square              Float?
  image_url_1         String?
  image_url_2         String?
  image_url_3         String?
  image_url_4         String?
  image_url_5         String?
  image_url_6         String?
  image_url_7         String?
  video_url_1         String?
  video_url_2         String?
  description         String?
  status              String?
  is_private_bathroom Boolean  @default(false)
  contact_phone       String?
  owner_id            String?
  
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  deleted_at          DateTime?

  favorites           Favorite[]
  reports             PropertyReport[]
  propertyFraudAlerts PropertyFraudAlert[]
  owner               User?    @relation("HouseOwner", fields: [owner_id], references: [id], onDelete: SetNull)
  roomDetails         HouseRoomDetail?

  @@index([city])
  @@index([district])
  @@index([city_code])
  @@index([ward_code])
  @@index([price])
  @@index([owner_id])
}

model HouseRoomDetail {
  id               String   @id @default(uuid())
  houseId          String   @unique @map("house_id")
  electricityPrice Int?     @map("electricity_price")
  waterPrice       Int?     @map("water_price")
  paymentMethod    String?  @map("payment_method")
  otherFees        String?  @map("other_fees")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  house            House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@map("house_room_details")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorRole   String?
  actionType  String
  entityType  String
  entityId    String
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id])
}

model LoginLog {
  id          String   @id @default(uuid())
  userId      String?
  role        String?
  ipAddress   String?
  userAgent   String?
  success     Boolean
  timestamp   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

model User {
  id         String     @id @default(uuid())
  name       String
  firstName  String?
  lastName   String?
  username   String     @unique
  email      String     @unique
  phone        String?
  password     String
  avatarUrl    String?    @map("avatar_url")
  coverUrl     String?    @map("cover_url")
  role         Role       @default(USER)
  status       String     @default("ACTIVE")
  name_updated_at DateTime?
  bio          String?
  deleted_at   DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  
  failed_attempts Int       @default(0)
  last_failed_attempt DateTime?
  locked_until DateTime?

  favorites    Favorite[]
  messages     Message[] @relation("MessageSender")
  ownedHouses  House[] @relation("HouseOwner")
  receivedMessages Message[] @relation("MessageReceiver")
  
  auditLogs    AuditLog[]
  loginLogs    LoginLog[]
  
  reportsSent     UserReport[] @relation("Reporter")
  reportsReceived UserReport[] @relation("ReportedUser")
  propertyReports PropertyReport[] @relation("PropertyReporter")
  supportTickets  SupportTicket[]
  
  riskScore       UserRiskScore?
  fraudAlerts     FraudAlert[]
  propertyFraudAlerts PropertyFraudAlert[]
  activityLogs    UserActivityLog[]
  securityEvents  SecurityEvent[]
  adminAuditLogs  AdminAuditLog[]
  refreshTokens   RefreshToken[]
}

model UserReport {
  id          String   @id @default(uuid())
  reporterId  String
  targetId    String
  reason      String
  details     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  target      User     @relation("ReportedUser", fields: [targetId], references: [id])
}

model PropertyReport {
  id          String   @id @default(uuid())
  reporterId  String
  houseId     String
  reason      String
  details     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User     @relation("PropertyReporter", fields: [reporterId], references: [id])
  house       House    @relation(fields: [houseId], references: [id])
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  messages     Message[] @relation("TicketMessages")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  houseId    String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  house      House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model Message {
  id         String   @id @default(uuid())
  userId     String
  receiverId String?
  senderId   String?
  ticketId   String?
  senderRole Role     @default(USER)
  content    String
  created_at DateTime @default(now())
  seen_at    DateTime?
  seen_by_role Role?

  user       User     @relation("MessageSender", fields: [userId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  ticket     SupportTicket? @relation("TicketMessages", fields: [ticketId], references: [id])

  @@index([receiverId])
}

model UserRiskScore {
  id        String   @id @default(uuid())
  userId    String   @unique
  score     Int      @default(0)
  factors   Json?    
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_risk_scores")
}

model FraudAlert {
  id          String   @id @default(uuid())
  userId      String?
  type        String   
  description String
  severity    String   
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("fraud_alerts")
}

model SuspiciousIP {
  id             String   @id @default(uuid())
  ipAddress      String   @unique
  country        String?
  city           String?
  loginAttempts  Int      @default(0)
  failedAttempts Int      @default(0)
  affectedUsers  Int      @default(0)
  riskLevel      String   
  status         String   @default("UNBLOCKED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("suspicious_ips")
}

model UserActivityLog {
  id           String   @id @default(uuid())
  userId       String
  activityType String   @map("activity_type")
  description  String
  ipAddress    String?  @map("ip_address")
  country      String?
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity_logs")
  @@index([userId])
  @@index([createdAt])
}

model PropertyFraudAlert {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  ownerId     String   @map("owner_id")
  fraudType   String   @map("fraud_type")
  description String
  severity    String   
  status      String   @default("OPEN")
  createdAt   DateTime @default(now()) @map("created_at")

  property    House    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("property_fraud_alerts")
  @@index([propertyId])
  @@index([ownerId])
}

model AdminLoginAttempt {
  id        String   @id @default(uuid())
  email     String
  ipAddress String   @map("ip_address")
  userAgent String?  @map("user_agent")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admin_login_attempts")
  @@index([email])
  @@index([ipAddress])
}

model SecurityEvent {
  id          String   @id @default(uuid())
  admin_id    String?
  event_type  String   @map("event_type")
  ip_address  String?
  country     String?
  description String
  created_at  DateTime @default(now())
  
  admin       User?    @relation(fields: [admin_id], references: [id])

  @@map("security_events")
  @@index([admin_id])
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  admin_id    String
  action      String
  target_type String
  target_id   String
  ip_address  String
  user_agent  String?
  created_at  DateTime @default(now())

  admin       User     @relation(fields: [admin_id], references: [id])

  @@map("admin_audit_logs")
  @@index([admin_id])
  @@index([created_at])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
