generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
  url        = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  USER
}

model House {
  id                  String   @id @default(uuid())
  original_id         String   @unique
  name                String
  property_type       String?
  address             String
  ward                String?
  district            String
  city                String
  latitude            Float?
  longitude           Float?
  price               Int?
  payment_method      String?
  bedrooms            Int?
  square              Float?
  image_url_1         String?
  image_url_2         String?
  image_url_3         String?
  image_url_4         String?
  image_url_5         String?
  image_url_6         String?
  image_url_7         String?
  video_url_1         String?
  video_url_2         String?
  description         String?
  status              String?
  is_private_bathroom Boolean  @default(false)
  contact_phone       String?
  owner_id            String?
  
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  deleted_at          DateTime?

  favorites           Favorite[]
  reports             PropertyReport[]
  owner               User?    @relation("HouseOwner", fields: [owner_id], references: [id], onDelete: SetNull)

  @@index([city])
  @@index([district])
  @@index([price])
  @@index([owner_id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorRole   String?
  actionType  String
  entityType  String
  entityId    String
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actor       User?    @relation(fields: [actorId], references: [id])
}

model LoginLog {
  id          String   @id @default(uuid())
  userId      String?
  role        String?
  ipAddress   String?
  userAgent   String?
  success     Boolean
  timestamp   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
}

model User {
  id         String     @id @default(uuid())
  name       String
  firstName  String?
  lastName   String?
  username   String     @unique
  email      String     @unique
  phone        String?
  password     String
  avatarUrl    String?    @map("avatar_url")
  coverUrl     String?    @map("cover_url")
  role         Role       @default(USER)
  status       String     @default("ACTIVE")
  locked_until DateTime?
  name_updated_at DateTime?
  bio          String?
  deleted_at   DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  favorites    Favorite[]
  messages     Message[] @relation("MessageSender")
  ownedHouses  House[] @relation("HouseOwner")
  receivedMessages Message[] @relation("MessageReceiver")
  
  auditLogs    AuditLog[]
  loginLogs    LoginLog[]
  
  reportsSent     UserReport[] @relation("Reporter")
  reportsReceived UserReport[] @relation("ReportedUser")
  propertyReports PropertyReport[] @relation("PropertyReporter")
  supportTickets  SupportTicket[]
}

model UserReport {
  id          String   @id @default(uuid())
  reporterId  String
  targetId    String
  reason      String
  details     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User     @relation("Reporter", fields: [reporterId], references: [id])
  target      User     @relation("ReportedUser", fields: [targetId], references: [id])
}

model PropertyReport {
  id          String   @id @default(uuid())
  reporterId  String
  houseId     String
  reason      String
  details     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter    User     @relation("PropertyReporter", fields: [reporterId], references: [id])
  house       House    @relation(fields: [houseId], references: [id])
}

model SupportTicket {
  id          String   @id @default(uuid())
  userId      String
  subject     String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  messages     Message[] @relation("TicketMessages")
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  houseId    String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  house      House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model Message {
  id         String   @id @default(uuid())
  userId     String
  receiverId String?
  senderId   String?
  ticketId   String?
  senderRole Role     @default(USER)
  content    String
  created_at DateTime @default(now())
  seen_at    DateTime?
  seen_by_role Role?

  user       User     @relation("MessageSender", fields: [userId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  ticket     SupportTicket? @relation("TicketMessages", fields: [ticketId], references: [id])

  @@index([receiverId])
}
