generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum Role {
  SUPER_ADMIN
  USER
}

model House {
  id                  String   @id @default(uuid())
  original_id         String   @unique
  name                String
  property_type       String?
  address             String
  district            String
  city                String
  latitude            Float?
  longitude           Float?
  price               Int?
  payment_method      String?
  bedrooms            Int?
  square              Float?
  image_url_1         String?
  image_url_2         String?
  image_url_3         String?
  image_url_4         String?
  image_url_5         String?
  image_url_6         String?
  image_url_7         String?
  video_url_1         String?
  video_url_2         String?
  description         String?
  status              String?
  is_private_bathroom Boolean  @default(false)
  contact_phone       String?
  owner_id            String?
  
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  deleted_at          DateTime?

  favorites           Favorite[]
  owner               User?    @relation("HouseOwner", fields: [owner_id], references: [id], onDelete: SetNull)

  @@index([city])
  @@index([district])
  @@index([price])
  @@index([owner_id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  actorRole   String?
  actionType  String
  entityType  String
  entityId    String
  beforeData  Json?
  afterData   Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model LoginLog {
  id          String   @id @default(uuid())
  userId      String?
  role        String?
  ipAddress   String?
  userAgent   String?
  success     Boolean
  timestamp   DateTime @default(now())
}

model User {
  id         String     @id @default(uuid())
  name       String
  username   String     @unique
  email      String     @unique
  phone        String?
  password     String
  avatarUrl    String?
  role         Role       @default(USER)
  status       String     @default("ACTIVE")
  locked_until DateTime?
  deleted_at   DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  favorites  Favorite[]
  messages   Message[] @relation("MessageSender")
  ownedHouses House[] @relation("HouseOwner")
  receivedMessages Message[] @relation("MessageReceiver")
}


model Favorite {
  id         String   @id @default(uuid())
  userId     String
  houseId    String
  created_at DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  house      House    @relation(fields: [houseId], references: [id], onDelete: Cascade)

  @@unique([userId, houseId])
}

model Message {
  id         String   @id @default(uuid())
  userId     String
  receiverId String?
  senderId   String?
  senderRole Role     @default(USER)
  content    String
  created_at DateTime @default(now())
  seen_at    DateTime?
  seen_by_role Role?

  user       User     @relation("MessageSender", fields: [userId], references: [id], onDelete: Cascade)
  receiver   User?    @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: SetNull)

  @@index([receiverId])
}
